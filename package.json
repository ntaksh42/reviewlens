{
  "name": "reviewlens",
  "displayName": "ReviewLens",
  "description": "Navigation-first pull request review for Azure DevOps.",
  "version": "0.0.1",
  "publisher": "reviewlens",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ntaksh42/reviewlens.git"
  },
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reviewlens",
          "title": "ReviewLens",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "views": {
      "reviewlens": [
        {
          "id": "reviewlens.prList",
          "name": "Pull Requests"
        },
        {
          "id": "reviewlens.changedFiles",
          "name": "Changed Files"
        },
        {
          "id": "reviewlens.impact",
          "name": "Impact"
        }
      ]
    },
    "commands": [
      {
        "command": "reviewlens.signIn",
        "title": "ReviewLens: Sign in (PAT)"
      },
      {
        "command": "reviewlens.signOut",
        "title": "ReviewLens: Sign out"
      },
      {
        "command": "reviewlens.refreshPrs",
        "title": "ReviewLens: Refresh Pull Requests",
        "icon": "$(refresh)"
      },
      {
        "command": "reviewlens.filterPrs",
        "title": "ReviewLens: Filter Pull Requests",
        "icon": "$(filter)"
      },
      {
        "command": "reviewlens.clearFilter",
        "title": "ReviewLens: Clear Pull Request Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "reviewlens.toggleViewed",
        "title": "ReviewLens: Toggle viewed",
        "icon": "$(check)"
      },
      {
        "command": "reviewlens.createOrReply",
        "title": "ReviewLens: Comment"
      },
      {
        "command": "reviewlens.addComment",
        "title": "ReviewLens: Add comment on current line"
      },
      {
        "command": "reviewlens.resolveThread",
        "title": "ReviewLens: Resolve thread",
        "icon": "$(check)"
      },
      {
        "command": "reviewlens.castVote",
        "title": "ReviewLens: Vote / complete pull request…",
        "icon": "$(thumbsup)"
      },
      {
        "command": "reviewlens.analyzeImpact",
        "title": "ReviewLens: Analyze Impact",
        "icon": "$(search)"
      },
      {
        "command": "reviewlens.attachToBranchPr",
        "title": "ReviewLens: Show PR comments for current branch",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "reviewlens.reviewLocally",
        "title": "ReviewLens: Review locally (checkout PR)",
        "icon": "$(repo-clone)"
      },
      {
        "command": "reviewlens.stopLocalReview",
        "title": "ReviewLens: Stop local review",
        "icon": "$(repo)"
      },
      {
        "command": "reviewlens.openInBrowser",
        "title": "ReviewLens: Open pull request in browser",
        "icon": "$(globe)"
      },
      {
        "command": "reviewlens.cleanWorktrees",
        "title": "ReviewLens: Clean up local-review worktrees…",
        "icon": "$(trash)"
      },
      {
        "command": "reviewlens.toggleViewedCurrent",
        "title": "ReviewLens: Toggle viewed (current file)"
      },
      {
        "command": "reviewlens.nextFile",
        "title": "ReviewLens: Next changed file"
      },
      {
        "command": "reviewlens.prevFile",
        "title": "ReviewLens: Previous changed file"
      },
      {
        "command": "reviewlens.nextChange",
        "title": "ReviewLens: Next change"
      },
      {
        "command": "reviewlens.prevChange",
        "title": "ReviewLens: Previous change"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "reviewlens.filterPrs",
          "when": "view == reviewlens.prList && !reviewlens.prFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "reviewlens.clearFilter",
          "when": "view == reviewlens.prList && reviewlens.prFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "reviewlens.attachToBranchPr",
          "when": "view == reviewlens.prList",
          "group": "navigation@0"
        },
        {
          "command": "reviewlens.refreshPrs",
          "when": "view == reviewlens.prList",
          "group": "navigation@2"
        },
        {
          "command": "reviewlens.analyzeImpact",
          "when": "view == reviewlens.impact",
          "group": "navigation"
        },
        {
          "command": "reviewlens.castVote",
          "when": "view == reviewlens.changedFiles && reviewlens.reviewActive",
          "group": "navigation@0"
        },
        {
          "command": "reviewlens.reviewLocally",
          "when": "view == reviewlens.changedFiles && reviewlens.reviewActive && !reviewlens.localActive",
          "group": "navigation@1"
        },
        {
          "command": "reviewlens.stopLocalReview",
          "when": "view == reviewlens.changedFiles && reviewlens.localActive",
          "group": "navigation@1"
        },
        {
          "command": "reviewlens.cleanWorktrees",
          "when": "view == reviewlens.changedFiles",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "reviewlens.toggleViewed",
          "when": "view == reviewlens.changedFiles && viewItem == changedFile",
          "group": "inline"
        },
        {
          "command": "reviewlens.openInBrowser",
          "when": "view == reviewlens.prList && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "reviewlens.openInBrowser",
          "when": "view == reviewlens.prList && viewItem == pullRequest",
          "group": "navigation"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "reviewlens.createOrReply",
          "group": "inline",
          "when": "commentController == reviewlens"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "reviewlens.resolveThread",
          "group": "navigation",
          "when": "commentController == reviewlens && commentThread == open"
        }
      ]
    },
    "keybindings": [
      {
        "command": "reviewlens.nextFile",
        "key": "shift+alt+]",
        "when": "reviewlens.reviewActive"
      },
      {
        "command": "reviewlens.prevFile",
        "key": "shift+alt+[",
        "when": "reviewlens.reviewActive"
      },
      {
        "command": "reviewlens.nextChange",
        "key": "alt+down",
        "when": "reviewlens.reviewActive && textInputFocus"
      },
      {
        "command": "reviewlens.prevChange",
        "key": "alt+up",
        "when": "reviewlens.reviewActive && textInputFocus"
      },
      {
        "command": "reviewlens.addComment",
        "key": "ctrl+[",
        "mac": "cmd+[",
        "when": "reviewlens.headEditor && editorTextFocus"
      },
      {
        "command": "reviewlens.castVote",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "reviewlens.reviewActive"
      },
      {
        "command": "reviewlens.toggleViewedCurrent",
        "key": "ctrl+k enter",
        "mac": "cmd+k enter",
        "when": "reviewlens.reviewActive"
      },
      {
        "command": "reviewlens.openInBrowser",
        "key": "ctrl+k b",
        "mac": "cmd+k b",
        "when": "reviewlens.reviewActive"
      },
      {
        "command": "reviewlens.reviewLocally",
        "key": "ctrl+k l",
        "mac": "cmd+k l",
        "when": "reviewlens.reviewActive && !reviewlens.localActive"
      },
      {
        "command": "reviewlens.stopLocalReview",
        "key": "ctrl+k l",
        "mac": "cmd+k l",
        "when": "reviewlens.reviewActive && reviewlens.localActive"
      }
    ],
    "configuration": {
      "title": "ReviewLens",
      "properties": {
        "reviewlens.orgUrl": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization URL, e.g. https://dev.azure.com/your-org"
        },
        "reviewlens.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name."
        },
        "reviewlens.repository": {
          "type": "string",
          "default": "",
          "description": "Optional: repository name to filter PRs. Empty = all repos in the project."
        },
        "reviewlens.baseRef": {
          "type": "string",
          "default": "main",
          "description": "Base ref for impact analysis on the open repository (git diff <baseRef>...HEAD)."
        },
        "reviewlens.localRepoPath": {
          "type": "string",
          "default": "",
          "description": "Optional: absolute path to a local clone, used for local (worktree) review only when its origin matches the PR's repo. Local review otherwise reuses a matching open folder, or auto-clones the repo on demand."
        },
        "reviewlens.localClonePartial": {
          "type": "boolean",
          "default": true,
          "description": "When auto-cloning for local review, use a blobless partial clone (--filter=blob:none): file contents are fetched on demand, so large repos clone quickly. Disable for a full clone (heavier, but whole-repo grep is fully offline)."
        },
        "reviewlens.localWorktreeLimit": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "How many cached local-review worktrees to keep before the least-recently-used ones are pruned from the extension's storage."
        },
        "reviewlens.autoAttachBranchPr": {
          "type": "boolean",
          "default": true,
          "description": "Automatically find the active pull request for the open workspace branch and show its review comments inline on the working-tree files. Disable to attach only via the \"Show PR comments for current branch\" command."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "azure-devops-node-api": "^14.0.0"
  }
}
